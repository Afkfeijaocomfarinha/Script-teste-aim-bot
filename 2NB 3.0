loadstring([[
local plrs=game:GetService("Players")local rs=game:GetService("RunService")local uis=game:GetService("UserInputService")local lp=plrs.LocalPlayer local cam=workspace.CurrentCamera local mouse=lp:GetMouse()
getgenv().Aimbot=true getgenv().Smoothness=1.0 getgenv().FOV=300 getgenv().ShowCircle=true getgenv().MenuKey="RightShift"
local circle=Drawing.new("Circle")circle.Thickness=2 circle.Visible=true circle.Color=Color3.fromRGB(0,150,255)circle.Transparency=0.3 circle.Radius=getgenv().FOV
local function gettarget()local target=nil local dist=getgenv().FOV local mpos=uis:GetMouseLocation()for _,v in pairs(plrs:GetPlayers())do if v~=lp and v.Character and v.Character:FindFirstChild("Humanoid")and v.Character.Humanoid.Health>0 then local part=v.Character:FindFirstChild("HeadHB")or v.Character:FindFirstChild("Head")or v.Character:FindFirstChild("UpperTorso")if part then local pos,on_screen=cam:WorldToViewportPoint(part.Position)if on_screen then local mag=(Vector2.new(pos.X,pos.Y)-mpos).Magnitude if mag<dist then dist=mag target=part end end end end end return target end
local sg=Instance.new("ScreenGui")sg.Name="AimbotGUI"sg.ResetOnSpawn=false sg.Parent=lp:WaitForChild("PlayerGui")
local main=Instance.new("Frame")main.Size=UDim2.new(0,300,0,350)main.Position=UDim2.new(0.5,-150,0.5,-175)main.BackgroundColor3=Color3.fromRGB(0,0,0)main.BackgroundTransparency=0 main.BorderSizePixel=0 main.Active=true main.Draggable=true main.Parent=sg
local border=Instance.new("Frame")border.Size=UDim2.new(1,2,1,2)border.Position=UDim2.new(0,-1,0,-1)border.BackgroundColor3=Color3.fromRGB(255,255,255)border.BackgroundTransparency=0.2 border.BorderSizePixel=0 border.ZIndex=0 border.Parent=main
local borderCorner=Instance.new("UICorner")borderCorner.CornerRadius=UDim.new(0,8)borderCorner.Parent=border
local mainCorner=Instance.new("UICorner")mainCorner.CornerRadius=UDim.new(0,8)mainCorner.Parent=main
local header=Instance.new("Frame")header.Size=UDim2.new(1,0,0,50)header.Position=UDim2.new(0,0,0,0)header.BackgroundColor3=Color3.fromRGB(0,0,0)header.BackgroundTransparency=0 header.BorderSizePixel=0 header.Parent=main
local headerCorner=Instance.new("UICorner")headerCorner.CornerRadius=UDim.new(0,8)headerCorner.Parent=header
local line=Instance.new("Frame")line.Size=UDim2.new(1,-20,0,1)line.Position=UDim2.new(0,10,0,50)line.BackgroundColor3=Color3.fromRGB(255,255,255)line.BackgroundTransparency=0.3 line.BorderSizePixel=0 line.Parent=main
local title=Instance.new("TextLabel")title.Size=UDim2.new(1,-40,0.5,0)title.Position=UDim2.new(0,15,0,8)title.BackgroundTransparency=1 title.Text="2NB AIMBOT PRO"title.TextColor3=Color3.fromRGB(255,255,255)title.Font=Enum.Font.GothamBold title.TextSize=16 title.TextXAlignment=Enum.TextXAlignment.Left title.Parent=header
local subtitle=Instance.new("TextLabel")subtitle.Size=UDim2.new(1,-40,0.5,0)subtitle.Position=UDim2.new(0,15,0,28)subtitle.BackgroundTransparency=1 subtitle.Text=lp.Name subtitle.TextColor3=Color3.fromRGB(180,180,200)subtitle.Font=Enum.Font.Gotham subtitle.TextSize=11 subtitle.TextXAlignment=Enum.TextXAlignment.Left subtitle.Parent=header
local discord=Instance.new("TextButton")discord.Size=UDim2.new(0,95,0,24)discord.Position=UDim2.new(1,-105,0.5,-12)discord.BackgroundColor3=Color3.fromRGB(88,101,242)discord.Text="Join Discord"discord.TextColor3=Color3.fromRGB(255,255,255)discord.Font=Enum.Font.GothamBold discord.TextSize=10 discord.BorderSizePixel=0 discord.Parent=header
local discordCorner=Instance.new("UICorner")discordCorner.CornerRadius=UDim.new(0,4)discordCorner.Parent=discord
discord.MouseButton1Click:Connect(function()setclipboard("https://discord.gg/5kqAxe8Hg")discord.Text="✅ Copied!"discord.BackgroundColor3=Color3.fromRGB(0,200,100)task.wait(2)discord.Text="Join Discord"discord.BackgroundColor3=Color3.fromRGB(88,101,242)print("📋 Link do Discord copiado!")end)
local close=Instance.new("TextButton")close.Size=UDim2.new(0,22,0,22)close.Position=UDim2.new(1,-30,0.5,-11)close.BackgroundColor3=Color3.fromRGB(200,50,50)close.BackgroundTransparency=0.3 close.Text="✕"close.TextColor3=Color3.fromRGB(255,255,255)close.Font=Enum.Font.GothamBold close.TextSize=12 close.BorderSizePixel=0 close.Parent=header
local closeCorner=Instance.new("UICorner")closeCorner.CornerRadius=UDim.new(0,4)closeCorner.Parent=close
close.MouseButton1Click:Connect(function()sg:Destroy()circle.Visible=false end)
local container=Instance.new("Frame")container.Size=UDim2.new(1,-20,1,-60)container.Position=UDim2.new(0,10,0,55)container.BackgroundTransparency=1 container.Parent=main
local function createToggle(name,varName,y)local bg=Instance.new("Frame")bg.Size=UDim2.new(1,0,0,32)bg.Position=UDim2.new(0,0,0,y)bg.BackgroundColor3=Color3.fromRGB(0,0,0)bg.BackgroundTransparency=0 bg.BorderSizePixel=0 bg.Parent=container local label=Instance.new("TextLabel")label.Size=UDim2.new(0.6,0,1,0)label.Position=UDim2.new(0,8,0,0)label.BackgroundTransparency=1 label.Text=name label.TextColor3=Color3.fromRGB(255,255,255)label.Font=Enum.Font.Gotham label.TextSize=13 label.TextXAlignment=Enum.TextXAlignment.Left label.Parent=bg local btn=Instance.new("TextButton")btn.Size=UDim2.new(0,45,0,20)btn.Position=UDim2.new(1,-50,0.5,-10)btn.BackgroundColor3=getgenv()[varName]and Color3.fromRGB(0,200,100)or Color3.fromRGB(50,50,50)btn.Text=getgenv()[varName]and"ON"or"OFF"btn.TextColor3=Color3.fromRGB(255,255,255)btn.Font=Enum.Font.GothamBold btn.TextSize=10 btn.BorderSizePixel=0 btn.Parent=bg local btnCorner=Instance.new("UICorner")btnCorner.CornerRadius=UDim.new(0,3)btnCorner.Parent=btn btn.MouseButton1Click:Connect(function()getgenv()[varName]=not getgenv()[varName]btn.BackgroundColor3=getgenv()[varName]and Color3.fromRGB(0,200,100)or Color3.fromRGB(50,50,50)btn.Text=getgenv()[varName]and"ON"or"OFF"end)return bg end
local function createSlider(name,varName,min,max,y)local bg=Instance.new("Frame")bg.Size=UDim2.new(1,0,0,48)bg.Position=UDim2.new(0,0,0,y)bg.BackgroundColor3=Color3.fromRGB(0,0,0)bg.BackgroundTransparency=0 bg.BorderSizePixel=0 bg.Parent=container local label=Instance.new("TextLabel")label.Size=UDim2.new(0.6,0,0,20)label.Position=UDim2.new(0,8,0,2)label.BackgroundTransparency=1 label.Text=name label.TextColor3=Color3.fromRGB(255,255,255)label.Font=Enum.Font.Gotham label.TextSize=12 label.TextXAlignment=Enum.TextXAlignment.Left label.Parent=bg local valueLabel=Instance.new("TextLabel")valueLabel.Size=UDim2.new(0.3,0,0,20)valueLabel.Position=UDim2.new(0.7,0,0,2)valueLabel.BackgroundTransparency=1 valueLabel.Text=getgenv()[varName]valueLabel.TextColor3=Color3.fromRGB(150,200,255)valueLabel.Font=Enum.Font.GothamBold valueLabel.TextSize=12 valueLabel.TextXAlignment=Enum.TextXAlignment.Right valueLabel.Parent=bg local bar=Instance.new("Frame")bar.Size=UDim2.new(1,-16,0,4)bar.Position=UDim2.new(0,8,0,30)bar.BackgroundColor3=Color3.fromRGB(50,50,50)bar.BorderSizePixel=0 bar.Parent=bg local barCorner=Instance.new("UICorner")barCorner.CornerRadius=UDim.new(0,2)barCorner.Parent=bar local fill=Instance.new("Frame")fill.Size=UDim2.new((getgenv()[varName]-min)/(max-min),0,1,0)fill.BackgroundColor3=Color3.fromRGB(0,150,255)fill.BorderSizePixel=0 fill.Parent=bar local fillCorner=Instance.new("UICorner")fillCorner.CornerRadius=UDim.new(0,2)fillCorner.Parent=fill local dragging=false bar.InputBegan:Connect(function(input)if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true end end)bar.InputEnded:Connect(function(input)if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)uis.InputChanged:Connect(function(input)if dragging and input.UserInputType==Enum.UserInputType.MouseMovement then local mpos=uis:GetMouseLocation()local barPos=bar.AbsolutePosition local barSize=bar.AbsoluteSize.X local pos=(mpos.X-barPos.X)/barSize pos=math.clamp(pos,0,1)local value=min+(max-min)*pos if varName=="Smoothness"then value=math.round(value*10)/10 else value=math.round(value)end getgenv()[varName]=value fill.Size=UDim2.new(pos,0,1,0)valueLabel.Text=getgenv()[varName]if varName=="FOV"then circle.Radius=value end end end)return bg end
local function createKeyBinder(name,varName,y)local bg=Instance.new("Frame")bg.Size=UDim2.new(1,0,0,32)bg.Position=UDim2.new(0,0,0,y)bg.BackgroundColor3=Color3.fromRGB(0,0,0)bg.BackgroundTransparency=0 bg.BorderSizePixel=0 bg.Parent=container local label=Instance.new("TextLabel")label.Size=UDim2.new(0.5,0,1,0)label.Position=UDim2.new(0,8,0,0)label.BackgroundTransparency=1 label.Text=name label.TextColor3=Color3.fromRGB(255,255,255)label.Font=Enum.Font.Gotham label.TextSize=12 label.TextXAlignment=Enum.TextXAlignment.Left label.Parent=bg local btn=Instance.new("TextButton")btn.Size=UDim2.new(0,75,0,20)btn.Position=UDim2.new(1,-80,0.5,-10)btn.BackgroundColor3=Color3.fromRGB(50,50,50)btn.Text=getgenv()[varName]btn.TextColor3=Color3.fromRGB(255,255,255)btn.Font=Enum.Font.GothamBold btn.TextSize=10 btn.BorderSizePixel=0 btn.Parent=bg local btnCorner=Instance.new("UICorner")btnCorner.CornerRadius=UDim.new(0,3)btnCorner.Parent=btn local waitingForKey=false btn.MouseButton1Click:Connect(function()waitingForKey=not waitingForKey if waitingForKey then btn.BackgroundColor3=Color3.fromRGB(255,150,50)btn.Text="..."else btn.BackgroundColor3=Color3.fromRGB(50,50,50)btn.Text=getgenv()[varName]end end)uis.InputBegan:Connect(function(input,gameProcessed)if waitingForKey and not gameProcessed then if input.UserInputType==Enum.UserInputType.Keyboard then local keyName=input.KeyCode.Name getgenv()[varName]=keyName btn.Text=keyName btn.BackgroundColor3=Color3.fromRGB(50,50,50)waitingForKey=false end end end)return bg end
createToggle("Aimbot","Aimbot",0)createToggle("Show FOV","ShowCircle",36)createSlider("Smoothness","Smoothness",0.1,1.0,72)createSlider("FOV Radius","FOV",50,500,124)createKeyBinder("Menu Key","MenuKey",176)
local footer=Instance.new("TextLabel")footer.Size=UDim2.new(1,0,0,20)footer.Position=UDim2.new(0,0,1,-25)footer.BackgroundTransparency=1 footer.Text="Clique direito para mirar • 2NB Aimbot Pro"footer.TextColor3=Color3.fromRGB(150,150,170)footer.Font=Enum.Font.Gotham footer.TextSize=9 footer.TextXAlignment=Enum.TextXAlignment.Center footer.Parent=container
local menuVisible=true uis.InputBegan:Connect(function(input,gameProcessed)if not gameProcessed and input.UserInputType==Enum.UserInputType.Keyboard then if input.KeyCode.Name==getgenv().MenuKey then menuVisible=not menuVisible main.Visible=menuVisible end end end)
rs.RenderStepped:Connect(function()circle.Radius=getgenv().FOV circle.Position=uis:GetMouseLocation()circle.Visible=getgenv().ShowCircle and getgenv().Aimbot if uis:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)and getgenv().Aimbot then local target=gettarget()if target then local pos,on_screen=cam:WorldToViewportPoint(target.Position)local mpos=uis:GetMouseLocation()local x=(pos.X-mpos.X)*getgenv().Smoothness local y=(pos.Y-mpos.Y)*getgenv().Smoothness if mousemoverel then mousemoverel(x,y)end end end end)
print("✅ 2NB Aimbot Pro carregado!")print("🔄 Pressione "..getgenv().MenuKey.." para abrir/fechar o menu")print("🎯 Botão direito do mouse para ativar")
]])()
