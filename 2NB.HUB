local uis = game:GetService("UserInputService")
local lp = plrs.LocalPlayer
local cam = workspace.CurrentCamera
local lighting = game:GetService("Lighting")
local debris = game:GetService("Debris")

-- ============================================
-- CONFIGURAÇÕES PADRÃO
-- ============================================
getgenv().Aimbot = true
getgenv().Smoothness = 1.0
getgenv().FOV = 300
getgenv().ShowCircle = true
getgenv().MenuKey = "RightShift"
getgenv().ESP = true
getgenv().AimbotKey = "X"
getgenv().ESPKey = "Z"
getgenv().TeamCheck = true
getgenv().MenuMinimized = true
getgenv().Saturation = 70 -- Começa com 70

-- ============================================
-- SISTEMA DE SALVAMENTO
-- ============================================
local function saveSettings()
    local data = "2NB|" ..
                 tostring(getgenv().Aimbot) .. "|" ..
                 tostring(getgenv().Smoothness) .. "|" ..
                 tostring(getgenv().FOV) .. "|" ..
                 tostring(getgenv().ShowCircle) .. "|" ..
                 getgenv().MenuKey .. "|" ..
                 tostring(getgenv().ESP) .. "|" ..
                 getgenv().AimbotKey .. "|" ..
                 getgenv().ESPKey .. "|" ..
                 tostring(getgenv().TeamCheck) .. "|" ..
                 tostring(getgenv().Saturation)
    
    pcall(function()
        setclipboard(data)
    end)
end

local function loadSettings()
    local success, clipboard = pcall(getclipboard)
    if not success or not clipboard then return false end
    if string.sub(clipboard, 1, 4) ~= "2NB|" then return false end
    
    local raw = string.sub(clipboard, 5)
    local parts = {}
    for part in string.gmatch(raw, "[^|]+") do
        table.insert(parts, part)
    end
    
    if #parts < 8 then return false end
    
    getgenv().Aimbot = parts[1] == "true"
    getgenv().Smoothness = tonumber(parts[2]) or 1.0
    getgenv().FOV = tonumber(parts[3]) or 300
    getgenv().ShowCircle = parts[4] == "true"
    getgenv().MenuKey = parts[5] or "RightShift"
    getgenv().ESP = parts[6] == "true"
    getgenv().AimbotKey = parts[7] or "X"
    getgenv().ESPKey = parts[8] or "Z"
    getgenv().TeamCheck = (parts[9] == nil) and true or (parts[9] == "true")
    getgenv().Saturation = tonumber(parts[10]) or 70
    
    return true
end

loadSettings()

-- ============================================
-- BOOST FPS MÁXIMO
