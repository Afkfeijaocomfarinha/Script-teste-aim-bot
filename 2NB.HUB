-- ============================================
-- CRIAR BOTÕES
-- ============================================
local function createToggle(name, varName, x, y)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0,100,0,45)
    bg.Position = UDim2.new(0,x,0,y)
    bg.BackgroundColor3 = Color3.fromRGB(0,0,0)
    bg.BackgroundTransparency = 0.3
    bg.BorderSizePixel = 1
    bg.BorderColor3 = Color3.fromRGB(100,200,255)
    bg.Parent = container
    
    local bgCorner = Instance.new("UICorner")
    bgCorner.CornerRadius = UDim.new(0,6)
    bgCorner.Parent = bg
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,0,16)
    label.Position = UDim2.new(0,0,0,1)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.fromRGB(100,200,255)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 9
    label.TextXAlignment = Enum.TextXAlignment.Center
    label.Parent = bg
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0,55,0,20)
    btn.Position = UDim2.new(0.5,-27.5,0,21)
    btn.BackgroundColor3 = getgenv()[varName] and Color3.fromRGB(100,200,255) or Color3.fromRGB(30,30,30)
    btn.Text = getgenv()[varName] and "❄️ ON" or "🌊 OFF"
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 8
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(100,200,255)
    btn.Parent = bg
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0,4)
    btnCorner.Parent = btn
    
    btn.MouseButton1Click:Connect(function()
        getgenv()[varName] = not getgenv()[varName]
        btn.BackgroundColor3 = getgenv()[varName] and Color3.fromRGB(100,200,255) or Color3.fromRGB(30,30,30)
        btn.Text = getgenv()[varName] and "❄️ ON" or "🌊 OFF"
        
        if varName == "ESP" then
            if getgenv().ESP then createESP() else clearESP() end
        end
        if varName == "TeamCheck" then
            if getgenv().ESP then createESP() end
        end
    end)
end

-- ============================================
-- SLIDER
-- ============================================
local function createSlider(name, varName, min, max, x, y, w)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0,w or 130,0,45)
    bg.Position = UDim2.new(0,x,0,y)
    bg.BackgroundColor3 = Color3.fromRGB(0,0,0)
    bg.BackgroundTransparency = 0.3
    bg.BorderSizePixel = 1
    bg.BorderColor3 = Color3.fromRGB(100,200,255)
    bg.Parent = container
    
    local bgCorner = Instance.new("UICorner")
    bgCorner.CornerRadius = UDim.new(0,6)
    bgCorner.Parent = bg
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,0,14)
    label.Position = UDim2.new(0,0,0,1)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.fromRGB(100,200,255)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 8
    label.TextXAlignment = Enum.TextXAlignment.Center
    label.Parent = bg
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(1,0,0,14)
    valueLabel.Position = UDim2.new(0,0,0,15)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = string.format("%.2f", getgenv()[varName])
    valueLabel.TextColor3 = Color3.fromRGB(150,200,240)
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 10
    valueLabel.TextXAlignment = Enum.TextXAlignment.Center
    valueLabel.Parent = bg
    
    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0.8,0,0,4)
    bar.Position = UDim2.new(0.1,0,0,33)
    bar.BackgroundColor3 = Color3.fromRGB(30,30,30)
    bar.BorderSizePixel = 0
    bar.Parent = bg
    
    local barCorner = Instance.new("UICorner")
    barCorner.CornerRadius = UDim.new(0,2)
    barCorner.Parent = bar
    
    local fill = Instance.new("Frame")
    local initPos = (getgenv()[varName] - min) / (max - min)
    fill.Size = UDim2.new(initPos,0,1,0)
    fill.BackgroundColor3 = Color3.fromRGB(100,200,255)
    fill.BorderSizePixel = 0
    fill.Parent = bar
    
    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(0,2)
    fillCorner.Parent = fill
    
    local dragging = false
    
    local function updateSlider(pos)
        pos = math.clamp(pos, 0, 1)
        local value = min + (max - min) * pos
        
        if varName == "Smoothness" then
            value = math.round(value * 10) / 10
        else
            value = math.round(value)
        end
        
        getgenv()[varName] = value
        fill.Size = UDim2.new(pos,0,1,0)
        valueLabel.Text = string.format("%.2f", value)
        
        if varName == "FOV" then
            circle.Radius = value
        end
    end
    
    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mpos = uis:GetMouseLocation()
            local barPos = bar.AbsolutePosition
            local barSize = bar.AbsoluteSize.X
            local pos = (mpos.X - barPos.X) / barSize
            updateSlider(pos)
            dragging = true
        end
    end)
    
    bar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    uis.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local mpos = uis:GetMouseLocation()
            local barPos = bar.AbsolutePosition
            local barSize = bar.AbsoluteSize.X
            local pos = (mpos.X - barPos.X) / barSize
            updateSlider(pos)
        end
    end)
    
    return bg
end

-- ============================================
-- CONTROLE DE SATURAÇÃO
-- ============================================
local function createSaturationControl(x, y)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0,180,0,45)
    bg.Position = UDim2.new(0,x,0,y)
    bg.BackgroundColor3 = Color3.fromRGB(0,0,0)
    bg.BackgroundTransparency = 0.3
    bg.BorderSizePixel = 1
    bg.BorderColor3 = Color3.fromRGB(100,200,255)
    bg.Parent = container
    
    local bgCorner = Instance.new("UICorner")
    bgCorner.CornerRadius = UDim.new(0,6)
    bgCorner.Parent = bg
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.6,0,0,16)
    label.Position = UDim2.new(0,5,0,1)
    label.BackgroundTransparency = 1
    label.Text = "🎨 Saturação"
    label.TextColor3 = Color3.fromRGB(100,200,255)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 9
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = bg
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0.3,0,0,16)
    valueLabel.Position = UDim2.new(0.7,0,0,1)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = getgenv().Saturation
    valueLabel.TextColor3 = Color3.fromRGB(150,200,240)
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 10
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Parent = bg
    
    -- Botão -
    local minusBtn = Instance.new("TextButton")
    minusBtn.Size = UDim2.new(0,30,0,24)
    minusBtn.Position = UDim2.new(0.1,0,0.5,-12)
    minusBtn.BackgroundColor3 = Color3.fromRGB(30,30,30)
    minusBtn.Text = "−"
    minusBtn.TextColor3 = Color3.fromRGB(255,255,255)
    minusBtn.Font = Enum.Font.GothamBold
    minusBtn.TextSize = 16
    minusBtn.BorderSizePixel = 1
    minusBtn.BorderColor3 = Color3.fromRGB(100,200,255)
    minusBtn.Parent = bg
    
    local minusCorner = Instance.new("UICorner")
    minusCorner.CornerRadius = UDim.new(0,4)
    minusCorner.Parent = minusBtn
    
    minusBtn.MouseButton1Click:Connect(function()
        local newValue = getgenv().Saturation - 10
        applySaturation(newValue)
        valueLabel.Text = getgenv().Saturation
    end)
    
    -- Botão +
    local plusBtn = Instance.new("TextButton")
    plusBtn.Size = UDim2.new(0,30,0,24)
    plusBtn.Position = UDim2.new(0.5,0,0.5,-12)
    plusBtn.BackgroundColor3 = Color3.fromRGB(30,30,30)
    plusBtn.Text = "+"
    plusBtn.TextColor3 = Color3.fromRGB(255,255,255)
    plusBtn.Font = Enum.Font.GothamBold
    plusBtn.TextSize = 16
    plusBtn.BorderSizePixel = 1
    plusBtn.BorderColor3 = Color3.fromRGB(100,200,255)
    plusBtn.Parent = bg
    
    local plusCorner = Instance.new("UICorner")
    plusCorner.CornerRadius = UDim.new(0,4)
    plusCorner.Parent = plusBtn
    
    plusBtn.MouseButton1Click:Connect(function()
        local newValue = getgenv().Saturation + 10
        applySaturation(newValue)
        valueLabel.Text = getgenv().Saturation
    end)
    
    -- Botão Reset
    local resetBtn = Instance.new("TextButton")
    resetBtn.Size = UDim2.new(0,30,0,24)
    resetBtn.Position = UDim2.new(0.85,0,0.5,-12)
    resetBtn.BackgroundColor3 = Color3.fromRGB(100,200,255)
    resetBtn.Text = "↺"
    resetBtn.TextColor3 = Color3.fromRGB(255,255,255)
    resetBtn.Font = Enum.Font.GothamBold
    resetBtn.TextSize = 14
    resetBtn.BorderSizePixel = 0
    resetBtn.Parent = bg
    
    local resetCorner = Instance.new("UICorner")
    resetCorner.CornerRadius = UDim.new(0,4)
    resetCorner.Parent = resetBtn
    
    resetBtn.MouseButton1Click:Connect(function()
        applySaturation(0)
        valueLabel.Text = getgenv().Saturation
    end)
    
    return bg
end

-- ============================================
-- KEY BINDER
-- ============================================
local function createKeyBinder(name, varName, x, y)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0,85,0,45)
    bg.Position = UDim2.new(0,x,0,y)
    bg.BackgroundColor3 = Color3.fromRGB(0,0,0)
    bg.BackgroundTransparency = 0.3
    bg.BorderSizePixel = 1
    bg.BorderColor3 = Color3.fromRGB(100,200,255)
    bg.Parent = container
    
    local bgCorner = Instance.new("UICorner")
    bgCorner.CornerRadius = UDim.new(0,6)
    bgCorner.Parent = bg
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,0,14)
    label.Position = UDim2.new(0,0,0,1)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.fromRGB(100,200,255)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 7
    label.TextXAlignment = Enum.TextXAlignment.Center
    label.Parent = bg
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0,45,0,20)
    btn.Position = UDim2.new(0.5,-22.5,0,21)
    btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
    btn.Text = getgenv()[varName]
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 8
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(100,200,255)
    btn.Parent = bg
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0,4)
    btnCorner.Parent = btn
    
    local waitingForKey = false
    
    btn.MouseButton1Click:Connect(function()
        waitingForKey = not waitingForKey
        if waitingForKey then
            btn.BackgroundColor3 = Color3.fromRGB(100,200,255)
            btn.Text = "..."
        else
            btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
            btn.Text = getgenv()[varName]
        end
    end)
    
    uis.InputBegan:Connect(function(input, gameProcessed)
        if waitingForKey and not gameProcessed then
            if input.UserInputType == Enum.UserInputType.Keyboard then
                local keyName = input.KeyCode.Name
                getgenv()[varName] = keyName
                btn.Text = keyName
                btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
                waitingForKey = false
            end
        end
    end)
end

-- ============================================
-- BOTÕES SAVE/LOAD
-- ============================================
local function createSaveLoadButtons(x, y)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0,200,0,45)
    bg.Position = UDim2.new(0,x,0,y)
    bg.BackgroundColor3 = Color3.fromRGB(0,0,0)
    bg.BackgroundTransparency = 0.3
    bg.BorderSizePixel = 1
    bg.BorderColor3 = Color3.fromRGB(100,200,255)
    bg.Parent = container
    
    local bgCorner = Instance.new("UICorner")
    bgCorner.CornerRadius = UDim.new(0,6)
    bgCorner.Parent = bg
    
    local saveBtn = Instance.new("TextButton")
    saveBtn.Size = UDim2.new(0.42,0,0.35,0)
    saveBtn.Position = UDim2.new(0.05,0,0.1,0)
    saveBtn.BackgroundColor3 = Color3.fromRGB(100,200,255)
    saveBtn.Text = "💾 SAVE"
    saveBtn.TextColor3 = Color3.fromRGB(255,255,255)
    saveBtn.Font = Enum.Font.GothamBold
    saveBtn.TextSize = 8
    saveBtn.BorderSizePixel = 0
    saveBtn.Parent = bg
    
    local saveCorner = Instance.new("UICorner")
    saveCorner.CornerRadius = UDim.new(0,4)
    saveCorner.Parent = saveBtn
    
    saveBtn.MouseButton1Click:Connect(function()
        saveSettings()
        saveBtn.Text = "✅ OK"
        saveBtn.BackgroundColor3 = Color3.fromRGB(100,255,200)
        wait(1.5)
        saveBtn.Text = "💾 SAVE"
        saveBtn.BackgroundColor3 = Color3.fromRGB(100,200,255)
    end)
    
    local loadBtn = Instance.new("TextButton")
    loadBtn.Size = UDim2.new(0.42,0,0.35,0)
    loadBtn.Position = UDim2.new(0.53,0,0.1,0)
    loadBtn.BackgroundColor3 = Color3.fromRGB(30,30,30)
    loadBtn.Text = "📂 LOAD"
    loadBtn.TextColor3 = Color3.fromRGB(255,255,255)
    loadBtn.Font = Enum.Font.GothamBold
    loadBtn.TextSize = 8
    loadBtn.BorderSizePixel = 1
    loadBtn.BorderColor3 = Color3.fromRGB(100,200,255)
    loadBtn.Parent = bg
    
    local loadCorner = Instance.new("UICorner")
    loadCorner.CornerRadius = UDim.new(0,4)
    loadCorner.Parent = loadBtn
    
    loadBtn.MouseButton1Click:Connect(function()
        if loadSettings() then
            applySaturation(getgenv().Saturation)
            circle.Radius = getgenv().FOV
            loadBtn.Text = "✅ OK"
            loadBtn.BackgroundColor3 = Color3.fromRGB(100,255,200)
            wait(1.5)
            loadBtn.Text = "📂 LOAD"
            loadBtn.BackgroundColor3 = Color3.fromRGB(30,30,30)
        else
            loadBtn.Text = "❌ ERRO"
            loadBtn.BackgroundColor3 = Color3.fromRGB(255,150,150)
            wait(1.5)
            loadBtn.Text = "📂 LOAD"
            loadBtn.BackgroundColor3 = Color3.fromRGB(30,30,30)
        end
    end)
end

