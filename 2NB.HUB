-- ============================================
-- GET TARGET (CORRIGIDO)
-- ============================================
local function gettarget()
    local target = nil
    local dist = getgenv().FOV
    local mpos = uis:GetMouseLocation()
    
    for _,v in pairs(plrs:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("Humanoid") then
            local hum = v.Character.Humanoid
            if hum.Health > 0 then
                if getgenv().TeamCheck then
                    if not isEnemy(v) then
                        continue
                    end
                end
                
                local part = v.Character:FindFirstChild("HeadHB") or v.Character:FindFirstChild("Head") or v.Character:FindFirstChild("UpperTorso")
                if part then
                    local pos, on_screen = cam:WorldToViewportPoint(part.Position)
                    if on_screen then
                        local mag = (Vector2.new(pos.X,pos.Y) - mpos).Magnitude
                        if mag < dist then
                            dist = mag
                            target = part
                        end
                    end
                end
            end
        end
    end
    return target
end

