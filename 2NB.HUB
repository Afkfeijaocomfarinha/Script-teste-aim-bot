createKeyBinder("ESP Key", "ESPKey", 425, 50)

createSaturationControl(5, 100)
createSaveLoadButtons(215, 100)

-- Rodapé
local footer = Instance.new("TextLabel")
footer.Size = UDim2.new(0.95,0,0,16)
footer.Position = UDim2.new(0.025,0,1,-18)
footer.BackgroundTransparency = 1
footer.Text = "🎨 Saturação inicia em 70 • Clique com botão direito para aimbot"
footer.TextColor3 = Color3.fromRGB(150,200,240)
footer.Font = Enum.Font.Gotham
footer.TextSize = 7
footer.TextXAlignment = Enum.TextXAlignment.Center
footer.Parent = container

-- ============================================
-- CONTROLES POR TECLA
-- ============================================
local menuVisible = not getgenv().MenuMinimized
uis.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.UserInputType == Enum.UserInputType.Keyboard then
        if input.KeyCode.Name == getgenv().MenuKey then
            menuVisible = not menuVisible
            main.Visible = menuVisible
            getgenv().MenuMinimized = not menuVisible
            toggleBtn.Text = getgenv().MenuMinimized and "▶ EXPANDIR" or "◀ MINIMIZAR"
        end
    end
end)

uis.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.UserInputType == Enum.UserInputType.Keyboard then
        local key = input.KeyCode.Name
        if key == getgenv().AimbotKey then
            getgenv().Aimbot = not getgenv().Aimbot
        end
        if key == getgenv().ESPKey then
            getgenv().ESP = not getgenv().ESP
            if getgenv().ESP then createESP() else clearESP() end
        end
    end
end)

-- ============================================
-- LOOP PRINCIPAL (AIMBOT FUNCIONANDO)
-- ============================================
rs.RenderStepped:Connect(function()
    circle.Radius = getgenv().FOV
    circle.Position = uis:GetMouseLocation()
    circle.Visible = getgenv().ShowCircle and getgenv().Aimbot
    
    if uis:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) and getgenv().Aimbot then
        local target = gettarget()
        if target then
            local pos, on_screen = cam:WorldToViewportPoint(target.Position)
            local mpos = uis:GetMouseLocation()
            local x = (pos.X - mpos.X) * getgenv().Smoothness
            local y = (pos.Y - mpos.Y) * getgenv().Smoothness
            if mousemoverel then
                mousemoverel(x,y)
            end
        end
    end
end)

-- ============================================
-- INICIALIZAR
-- ============================================
if getgenv().ESP then
    wait(0.5)
    createESP()
end

-- Aplica saturação 70 ao iniciar
applySaturation(70)

print("❄️ 2NB Aimbot Pro - Saturação 70!")
print("🔄 Pressione "..getgenv().MenuKey.." para abrir/fechar o menu")
print("🎯 Botão direito do mouse para ativar")
print("🎨 Saturação iniciada em 70")
print("🔫 Pressione "..getgenv().AimbotKey.." para ligar/desligar Aimbot")
print("👁️ Pressione "..getgenv().ESPKey.." para ligar/desligar ESP")
print("⚔️ Team Check: " .. (getgenv().TeamCheck and "✅ ATIVADO" or "❌ DESATIVADO"))
