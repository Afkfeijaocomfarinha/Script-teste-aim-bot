    debris:SetMaximumItems(20)
end)

-- ============================================
-- FUNÇÃO PARA AJUSTAR SATURAÇÃO
-- ============================================
local function applySaturation(value)
    value = math.clamp(value, -100, 100)
    getgenv().Saturation = value
    
    pcall(function()
        if value >= 0 then
            local bright = 0.3 + (value / 200) * 0.7
            lighting.Brightness = math.clamp(bright, 0.1, 1.0)
            lighting.Ambient = Color3.fromRGB(
                math.clamp(30 + value * 2, 0, 200),
                math.clamp(30 + value * 2, 0, 200),
                math.clamp(30 + value * 2, 0, 200)
            )
            lighting.OutdoorAmbient = Color3.fromRGB(
                math.clamp(30 + value * 2, 0, 200),
                math.clamp(30 + value * 2, 0, 200),
                math.clamp(30 + value * 2, 0, 200)
            )
        else
            local dim = 1 + (value / 100) * 0.8
            lighting.Brightness = math.clamp(0.3 * dim, 0.05, 0.5)
            local gray = math.clamp(30 + value * 1.5, 0, 100)
            lighting.Ambient = Color3.fromRGB(gray, gray, gray)
            lighting.OutdoorAmbient = Color3.fromRGB(gray, gray, gray)
        end
        
        local colorCorrection = lighting:FindFirstChild("ColorCorrection")
        if not colorCorrection then
            colorCorrection = Instance.new("ColorCorrectionEffect")
            colorCorrection.Name = "ColorCorrection"
            colorCorrection.Parent = lighting
        end
        
        if colorCorrection then
            local satValue = (value + 100) / 200
            colorCorrection.Saturation = satValue
            colorCorrection.Brightness = 0
            colorCorrection.Contrast = 0
        end
    end)
end

-- ============================================
-- FUNÇÃO PARA VERIFICAR TIME (RIVALS)
-- ============================================
local function getPlayerTeam(player)
    if not player or not player.Character then return nil end
    
    local character = player.Character
    
    -- 1. Verificar atributos do Humanoid
    local hum = character:FindFirstChild("Humanoid")
    if hum then
        local teamAttr = hum:GetAttribute("Team") or 
                        hum:GetAttribute("TeamColor") or
                        hum:GetAttribute("TeamTag") or
                        hum:GetAttribute("team")
        if teamAttr then
            return tostring(teamAttr)
        end
        
        local humTeam = hum:FindFirstChild("Team") or 
                       hum:FindFirstChild("TeamColor") or
                       hum:FindFirstChild("TeamTag") or
                       hum:FindFirstChild("team")
        if humTeam then
            if humTeam:IsA("StringValue") or humTeam:IsA("TextLabel") then
                return humTeam.Value
            elseif humTeam:IsA("NumberValue") or humTeam:IsA("IntValue") then
                return humTeam.Value == 1 and "Blue" or "Red"
            elseif humTeam:IsA("ObjectValue") and humTeam.Value then
                return tostring(humTeam.Value)
            end
        end
    end
    
    -- 2. Verificar no personagem
    local teamValue = character:FindFirstChild("Team") or 
                     character:FindFirstChild("TeamColor") or
                     character:FindFirstChild("TeamTag") or
                     character:FindFirstChild("team") or
                     character:FindFirstChild("teams")
    
    if teamValue then
        if teamValue:IsA("StringValue") or teamValue:IsA("TextLabel") then
            return teamValue.Value
        elseif teamValue:IsA("NumberValue") or teamValue:IsA("IntValue") then
            return teamValue.Value == 1 and "Blue" or "Red"
        elseif teamValue:IsA("ObjectValue") and teamValue.Value then
            return tostring(teamValue.Value)
        elseif teamValue:IsA("Color3Value") then
            return tostring(teamValue.Value)
        end
    end
    
    -- 3. Verificar no jogador
    local playerTeam = player:FindFirstChild("Team") or 
                       player:FindFirstChild("TeamColor") or
                       player:FindFirstChild("TeamTag") or
                       player:FindFirstChild("team")
    if playerTeam then
        if playerTeam:IsA("StringValue") or playerTeam:IsA("TextLabel") then
            return playerTeam.Value
        elseif playerTeam:IsA("NumberValue") or playerTeam:IsA("IntValue") then
            return playerTeam.Value == 1 and "Blue" or "Red"
        end
    end
    
    -- 4. Verificar por cores (método alternativo)
    local torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
    if torso then
        local brickColor = torso.BrickColor
        if brickColor then
            local colorName = brickColor.Name:lower()
            if colorName:find("blue") or colorName:find("cyan") then
                return "Blue"
            elseif colorName:find("red") or colorName:find("crimson") then
                return "Red"
            elseif colorName:find("green") then
                return "Green"
            elseif colorName:find("yellow") or colorName:find("gold") then
                return "Yellow"
            end
        end
    end
    
    return nil
end

local function isEnemy(player)
    if player == lp then return false end
    if not getgenv().TeamCheck then return true end
    
    local playerTeam = getPlayerTeam(player)
    local myTeam = getPlayerTeam(lp)
    
    if not playerTeam or not myTeam then 
        return true
    end
    
    return playerTeam ~= myTeam
end

-- ============================================
-- ESP
-- ============================================
local espList = {}
local function clearESP()
    for _,v in pairs(espList) do
        pcall(function() v:Remove() end)
    end
    espList = {}
end

local function createESP()
    clearESP()
    
    for _,v in pairs(plrs:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("Humanoid") then
            local hum = v.Character.Humanoid
            if hum.Health > 0 then
                if getgenv().TeamCheck and not isEnemy(v) then
                    continue
                end
                
                local head = v.Character:FindFirstChild("Head") or v.Character:FindFirstChild("UpperTorso")
                if head then
                    pcall(function()
                        local bill = Instance.new("BillboardGui")
                        bill.Size = UDim2.new(0,140,0,50)
                        bill.StudsOffset = Vector3.new(0,2.8,0)
                        bill.AlwaysOnTop = true
                        bill.Parent = head
                        
                        local frame = Instance.new("Frame")
                        frame.Size = UDim2.new(1,0,1,0)
                        frame.BackgroundColor3 = Color3.fromRGB(200,230,255)
                        frame.BackgroundTransparency = 0.3
                        frame.BorderSizePixel = 1
                        frame.BorderColor3 = Color3.fromRGB(150,200,255)
                        frame.Parent = bill
                        
                        local frameCorner = Instance.new("UICorner")
                        frameCorner.CornerRadius = UDim.new(0,5)
                        frameCorner.Parent = frame
                        
                        local teamLabel = Instance.new("TextLabel")
                        teamLabel.Size = UDim2.new(1,0,0.2,0)
                        teamLabel.Position = UDim2.new(0,0,0,0)
                        teamLabel.BackgroundTransparency = 1
                        teamLabel.Text = "⚔️ INIMIGO"
                        teamLabel.TextColor3 = Color3.fromRGB(100,180,255)
                        teamLabel.Font = Enum.Font.GothamBold
                        teamLabel.TextSize = 8
                        teamLabel.TextXAlignment = Enum.TextXAlignment.Center
                        teamLabel.Parent = frame
                        
                        local nameLabel = Instance.new("TextLabel")
                        nameLabel.Size = UDim2.new(1,0,0.4,0)
                        nameLabel.Position = UDim2.new(0,0,0.2,0)
                        nameLabel.BackgroundTransparency = 1
                        nameLabel.Text = tostring(v.DisplayName or v.Name)
                        nameLabel.TextColor3 = Color3.fromRGB(200,230,255)
                        nameLabel.Font = Enum.Font.GothamBold
                        nameLabel.TextSize = 12
                        nameLabel.TextXAlignment = Enum.TextXAlignment.Center
                        nameLabel.Parent = frame
                        
                        local userLabel = Instance.new("TextLabel")
                        userLabel.Size = UDim2.new(1,0,0.2,0)
                        userLabel.Position = UDim2.new(0,0,0.6,0)
                        userLabel.BackgroundTransparency = 1
                        userLabel.Text = "@"..v.Name
                        userLabel.TextColor3 = Color3.fromRGB(180,210,240)
                        userLabel.Font = Enum.Font.Gotham
                        userLabel.TextSize = 8
                        userLabel.TextXAlignment = Enum.TextXAlignment.Center
                        userLabel.Parent = frame
                        
                        local hpLabel = Instance.new("TextLabel")
                        hpLabel.Size = UDim2.new(1,0,0.25,0)
                        hpLabel.Position = UDim2.new(0,0,0.75,0)
                        hpLabel.BackgroundTransparency = 1
                        hpLabel.Text = "💙 "..math.floor(hum.Health).."/150"
                        hpLabel.TextColor3 = Color3.fromRGB(150,200,255)
                        hpLabel.Font = Enum.Font.GothamBold
                        hpLabel.TextSize = 10
                        hpLabel.TextXAlignment = Enum.TextXAlignment.Center
                        hpLabel.Parent = frame
                        
                        local hpBar = Instance.new("Frame")
                        hpBar.Size = UDim2.new(1,-10,0,3)
                        hpBar.Position = UDim2.new(0,5,1,-3)
                        hpBar.BackgroundColor3 = Color3.fromRGB(100,150,200)
                        hpBar.BorderSizePixel = 0
                        hpBar.Parent = frame
                        
                        local hpBarCorner = Instance.new("UICorner")
                        hpBarCorner.CornerRadius = UDim.new(0,2)
                        hpBarCorner.Parent = hpBar
                        
                        local hpFill = Instance.new("Frame")
                        hpFill.Size = UDim2.new(math.clamp(hum.Health/150,0,1),0,1,0)
                        hpFill.BackgroundColor3 = Color3.fromRGB(100,200,255)
                        hpFill.BorderSizePixel = 0
                        hpFill.Parent = hpBar
                        
                        local hpFillCorner = Instance.new("UICorner")
                        hpFillCorner.CornerRadius = UDim.new(0,2)
                        hpFillCorner.Parent = hpFill
                        
                        table.insert(espList, bill)
                    end)
                end
            end
        end
    end
end

